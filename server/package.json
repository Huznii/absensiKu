{
  "name": "absensi-siswa-server",
  "version": "1.0.0",
  "description": "Backend API untuk Aplikasi Absensi Siswa",
  "main": "server.js",
  "scripts": {
    "postinstall": "npx prisma generate",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:reset": "npx prisma migrate reset --force",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "qrcode": "^1.5.4",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "prisma": "^6.6.0"
  }
}
